---
import { Image } from 'astro:assets';
import { CONTACT, SITE } from '../config';
import vimsLogoLight from '../assets/vims-logo-light.webp';
import vimsLogoDark from '../assets/vims-logo-dark.webp';

const year = new Date().getFullYear();
const vimsAlt =
  'William & Mary and the Virginia Institute of Marine Science — Batten School of Coastal & Marine Sciences';
---

<footer>
  <div class="container inner">
    <div class="col">
      <p class="lab">{SITE.title} — {SITE.fullName}</p>
      <p class="muted">
        {CONTACT.institution}<br />
        {CONTACT.school}<br />
        {CONTACT.address}
      </p>
    </div>
    <div class="col links">
      <ul>
        <li><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
        <li><a href={CONTACT.github}>GitHub</a></li>
        <li><a href="/news/rss.xml">RSS</a></li>
      </ul>
    </div>
    <a class="affiliation" href="https://www.vims.edu/">
      <Image class="logo-light" src={vimsLogoLight} alt={vimsAlt} widths={[320, 640]} sizes="320px" />
      <Image class="logo-dark" src={vimsLogoDark} alt={vimsAlt} widths={[320, 640]} sizes="320px" />
    </a>
  </div>
  <div class="container copyright muted">
    © {year} {SITE.fullName}
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-block-start: var(--space-2xl);
    padding-block: var(--space-lg);
    font-size: var(--text-sm);
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg) clamp(var(--space-lg), 5vw, var(--space-2xl));
  }

  .lab {
    font-family: var(--font-mono);
    font-weight: 600;
    margin-block-end: var(--space-xs);
  }

  .muted {
    color: var(--text-muted);
  }


  /* 19rem basis makes the logo's height match the 3-line links column at
     full width; `flex: 0 1` lets it shrink through intermediate widths
     instead of wrapping onto a lonely second row. */
  .affiliation {
    display: block;
    flex: 0 1 19rem;
    min-width: 5.5rem;
    margin-inline-start: auto;
    align-self: flex-start;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .affiliation img {
    width: 100%;
    height: auto;
  }

  /* Below this width the columns themselves start crowding; stack the
     logo left-aligned at a fixed size instead of letting it shrink or
     wrap to a lonely right-aligned row. */
  @media (max-width: 52rem) {
    .affiliation {
      flex: 0 0 auto;
      width: min(16rem, 100%);
      margin-inline-start: 0;
    }
  }

  .affiliation:hover {
    opacity: 1;
  }

  .affiliation .logo-dark {
    display: none;
  }

  :global([data-theme='dark']) .affiliation .logo-light {
    display: none;
  }

  :global([data-theme='dark']) .affiliation .logo-dark {
    display: block;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .affiliation .logo-light {
      display: none;
    }

    :global(:root:not([data-theme='light'])) .affiliation .logo-dark {
      display: block;
    }
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .copyright {
    margin-block-start: var(--space-lg);
  }
</style>
