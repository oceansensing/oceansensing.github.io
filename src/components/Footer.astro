---
import { CONTACT, SITE } from '../config';

const year = new Date().getFullYear();
---

<footer>
  <div class="container inner">
    <div class="col">
      <p class="lab">{SITE.title} — {SITE.fullName}</p>
      <p class="muted">
        {CONTACT.institution}<br />
        {CONTACT.school}<br />
        {CONTACT.address}
      </p>
    </div>
    <div class="col">
      <ul>
        <li><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></li>
        <li><a href={CONTACT.github}>GitHub</a></li>
        <li><a href="/news/rss.xml">RSS</a></li>
      </ul>
    </div>
  </div>
  <div class="container copyright muted">
    © {year} {SITE.fullName}
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-block-start: var(--space-2xl);
    padding-block: var(--space-lg);
    font-size: var(--text-sm);
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg) var(--space-2xl);
  }

  .lab {
    font-family: var(--font-mono);
    font-weight: 600;
    margin-block-end: var(--space-xs);
  }

  .muted {
    color: var(--text-muted);
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .copyright {
    margin-block-start: var(--space-lg);
  }
</style>
