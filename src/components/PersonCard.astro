---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  person: CollectionEntry<'people'>;
}

const { person } = Astro.props;
const { name, role, photo, email, links, years, currentPosition } = person.data;
const { Content } = await render(person);

const externalLinks = [
  links.website && { label: 'Website', url: links.website },
  links.scholar && { label: 'Scholar', url: links.scholar },
  links.orcid && { label: 'ORCID', url: `https://orcid.org/${links.orcid}` },
  links.github && { label: 'GitHub', url: `https://github.com/${links.github}` },
  links.linkedin && { label: 'LinkedIn', url: links.linkedin },
].filter((l): l is { label: string; url: string } => Boolean(l));
---

<article>
  {photo && <Image class="photo" src={photo} alt={`Photo of ${name}`} widths={[160, 320]} sizes="160px" />}
  <div>
    <h3>{name}</h3>
    <p class="eyebrow">{role}{years && ` · ${years}`}</p>
    {currentPosition && <p class="now">Now: {currentPosition}</p>}
    <div class="bio"><Content /></div>
    {
      (email || externalLinks.length > 0) && (
        <ul class="links">
          {email && (
            <li>
              <a href={`mailto:${email}`}>Email</a>
            </li>
          )}
          {externalLinks.map((l) => (
            <li>
              <a href={l.url}>{l.label}</a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  article {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--border);
  }

  .photo {
    width: 9rem;
    border-radius: var(--radius);
    flex-shrink: 0;
  }

  h3 {
    margin-block-end: var(--space-2xs);
  }

  .now {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-block-start: var(--space-2xs);
  }

  .bio {
    margin-block: var(--space-xs);
    max-width: var(--prose-width);
  }

  .bio :global(p) {
    margin-block-end: var(--space-xs);
  }

  .links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  @media (max-width: 30rem) {
    article {
      flex-direction: column;
    }
  }
</style>
