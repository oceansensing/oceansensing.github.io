---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const byTitle = (a: { data: { title: string } }, b: { data: { title: string } }) =>
  a.data.title.localeCompare(b.data.title, 'en', { sensitivity: 'base' });

const datasets = (await getCollection('datasets')).sort(byTitle);
const software = (await getCollection('software')).sort(byTitle);
---

<BaseLayout
  title="Data & Tools"
  description="Datasets and open-source software from the Collaboratory for Physical Oceanography."
>
  <div class="container">
    <h1>Data &amp; Tools</h1>
    <p class="intro">
      We believe ocean observations belong in the open. Our data flow to public
      archives, and our code lives on GitHub.
    </p>

    <section>
      <h2><span class="eyebrow">Open data</span> Datasets</h2>
      <ul>
        {
          datasets.map(({ data }) => (
            <li>
              <h3>
                <a href={data.url}>{data.title}</a>
              </h3>
              <p>{data.description}</p>
              <p class="meta">
                {data.archive}
                {data.doi && (
                  <>
                    {' · '}
                    <a href={`https://doi.org/${data.doi}`}>doi:{data.doi}</a>
                  </>
                )}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section>
      <h2><span class="eyebrow">Open source</span> Software</h2>
      <ul>
        {
          software.map(({ data }) => (
            <li>
              <h3>
                <a href={data.repo}>{data.title}</a>
              </h3>
              <p>{data.description}</p>
              {data.language && <p class="meta">{data.language}</p>}
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-block: var(--space-xl) var(--space-md);
  }

  .intro {
    color: var(--text-muted);
    max-width: var(--prose-width);
    margin-block-end: var(--space-xl);
  }

  h2 {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-block-end: var(--space-md);
  }

  section {
    margin-block-end: var(--space-2xl);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    border-top: 1px solid var(--border);
    padding-block: var(--space-md);
    max-width: var(--prose-width);
  }

  li p {
    color: var(--text-muted);
    margin-block-start: var(--space-2xs);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
