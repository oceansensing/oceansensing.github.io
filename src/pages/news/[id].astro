---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, description, cover } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={title} description={description}>
  <article class="container">
    <p class="eyebrow"><FormattedDate date={date} /></p>
    <h1>{title}</h1>
    {cover && <Image class="cover" src={cover} alt="" widths={[800, 1400]} sizes="(max-width: 72rem) 100vw, 1100px" />}
    <div class="prose">
      <Content />
    </div>
    <p class="back"><a href="/news/">← All news</a></p>
  </article>
</BaseLayout>

<style>
  article {
    padding-block: var(--space-xl);
  }

  h1 {
    margin-block: var(--space-xs) var(--space-lg);
    max-width: 26ch;
  }

  .cover {
    border-radius: var(--radius);
    margin-block-end: var(--space-lg);
  }

  .back {
    margin-block-start: var(--space-xl);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
