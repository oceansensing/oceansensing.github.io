---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PersonCard from '../components/PersonCard.astro';

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const current = (await getCollection('people', ({ data }) => data.status === 'current')).sort(byOrder);
const alumni = (await getCollection('people', ({ data }) => data.status === 'alumni')).sort(byOrder);
const firstYear = (year: string) => Number.parseInt(year, 10) || 0;
const interns = (await getCollection('interns')).sort(
  (a, b) =>
    firstYear(b.data.year) - firstYear(a.data.year) || a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout title="People" description="Current members and alumni of the Collaboratory for Physical Oceanography.">
  <div class="container">
    <h1>People</h1>
    <section>
      {current.map((person) => <PersonCard person={person} />)}
    </section>
    <section>
      <h2><span class="eyebrow">Where they went</span> Alumni</h2>
      {alumni.map((person) => <PersonCard person={person} />)}
    </section>
    <section>
      <h2><span class="eyebrow">Research experiences</span> Undergraduate interns</h2>
      <ul class="interns">
        {
          interns.map(({ data }) => (
            <li>
              <span class="intern-name">
                {data.linkedin ? <a href={data.linkedin}>{data.name}</a> : data.name}
              </span>
              <span class="intern-role">
                {data.role} · {data.year}
              </span>
              <span class="intern-project">{data.project}</span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-block: var(--space-xl) var(--space-md);
  }

  h2 {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-block-start: var(--space-2xl);
    margin-block-end: var(--space-md);
  }

  section:last-child {
    margin-block-end: var(--space-xl);
  }

  .interns {
    list-style: none;
    padding: 0;
  }

  .interns li {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    border-top: 1px solid var(--border);
    padding-block: var(--space-sm);
    max-width: var(--prose-width);
  }

  .intern-name {
    font-weight: 550;
  }

  .intern-role {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .intern-project {
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>
