---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const byOrder = (a: { data: { order: number } }, b: { data: { order: number } }) =>
  a.data.order - b.data.order;

const projects = await getCollection('projects');
const active = projects.filter((p) => p.data.status === 'active').sort(byOrder);
const past = projects.filter((p) => p.data.status === 'completed').sort(byOrder);
---

<BaseLayout title="Research" description="Research projects of the Collaboratory for Physical Oceanography.">
  <div class="container">
    <h1>Research</h1>
    <p class="intro">
      Our work centers on polar ocean dynamics, coastal circulation, submarine
      canyons, upper-ocean dynamics, and ocean turbulence — observed with
      autonomous platforms we help develop.
    </p>
    {past.length > 0 && <h2><span class="eyebrow">Ongoing</span> Active projects</h2>}
    <div class="grid">
      {active.map((project) => <ProjectCard project={project} />)}
    </div>
    {
      past.length > 0 && (
        <section>
          <h2><span class="eyebrow">Completed</span> Past projects</h2>
          <div class="grid">
            {past.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

<style>
  h1 {
    margin-block: var(--space-xl) var(--space-md);
  }

  .intro {
    color: var(--text-muted);
    max-width: var(--prose-width);
    margin-block-end: var(--space-xl);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-md);
  }

  h2 {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    margin-block-end: var(--space-md);
  }

  section {
    margin-block-start: var(--space-2xl);
    margin-block-end: var(--space-xl);
  }
</style>
